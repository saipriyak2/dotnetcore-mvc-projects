@using PizzaPanda_Store.Models
@model Ingredient
@{
    ViewBag.Title = "Ingredient Details";
}
<h4>@Model.Name Details</h4>

<table class="table">
    <thead>
        <tr>
            <th>Product</th>
            <th>Description</th>
            <th>Price</th>
        </tr>
    </thead>
    <tbody>
        @foreach(var productIngredient in Model.ProductIngredients)
        {
            <tr>
               <td>@productIngredient.Product.Name</td>
                <td>@productIngredient.Product.Description </td>
                <td>@productIngredient.Product.Price </td>
            </tr>
        }
    </tbody>
</table>
}
<div>
    <a asp-action="Index">Back to List</a>
</div>