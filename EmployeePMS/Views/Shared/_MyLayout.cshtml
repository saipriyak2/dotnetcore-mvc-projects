<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title - Competency PMS</title>
    @RenderSection("Styles", required: false)


    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            padding-top: 4.5rem;
            background-color: #f8f9fa;
        }

        footer {
            background-color: #343a40;
            color: white;
            padding: 1rem 0;
            margin-top: 2rem;
        }

        .navbar-brand {
            font-weight: bold;
        }
    </style>
</head>
<body>

    <!-- ✅ Main Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top">
        <div class="container-fluid">
            <a class="navbar-brand" href="#">Competency PMS</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNavbar">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                    <!-- 🔹 User Management Menu -->
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            User Management
                        </a>
                        <ul class="dropdown-menu" aria-labelledby="userDropdown">
                            <li>@Html.ActionLink("View Users", "Index", "UserManagement", null, new { @class = "dropdown-item" })</li>
                            <li>@Html.ActionLink("Create User", "CreateRegister", "UserManagement", null, new { @class = "dropdown-item" })</li>
                            <li>@Html.ActionLink("Edit User", "Edit", "UserManagement", null, new { @class = "dropdown-item" })</li>
                            <li>@Html.ActionLink("Delete User", "Delete", "UserManagement", null, new { @class = "dropdown-item" })</li>
                        </ul>
                    </li>

                    <!-- 🔹 Role Management Menu -->
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="roleDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            Role Management
                        </a>
                        <ul class="dropdown-menu" aria-labelledby="roleDropdown">
                            <li>@Html.ActionLink("View Roles", "Index", "RoleManagement", null, new { @class = "dropdown-item" })</li>
                            <li>@Html.ActionLink("Create Role", "Create", "RoleManagement", null, new { @class = "dropdown-item" })</li>
                            <li>@Html.ActionLink("Edit Role", "Edit", "RoleManagement", null, new { @class = "dropdown-item" })</li>
                        </ul>
                    </li>

                    <!-- 🔹 Login -->
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="roleDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            User Activities
                        </a>
                        <ul class="dropdown-menu" aria-labelledby="roleDropdown">
                            <li>@Html.ActionLink("Login", "Login", "UserManagement", null, new { @class = "dropdown-item" })</li>
                            <li>@Html.ActionLink("ChangePassword", "ChangePassword", "UserManagement", null, new { @class = "dropdown-item" })</li>
                            
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="roleDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            Designation Info
                        </a>
                        <ul class="dropdown-menu" aria-labelledby="roleDropdown">
                            <li>@Html.ActionLink("View", "Index", "DesignationMgnt", null, new { @class = "dropdown-item" })</li>
                            <li>@Html.ActionLink("Create", "Create", "DesignationMgnt", null, new { @class = "dropdown-item" })</li>
                            <li>@Html.ActionLink("Edit", "Edit", "DesignationMgnt", null, new { @class = "dropdown-item" })</li>

                        </ul>
                    </li>

                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="roleDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            Assessment Info
                        </a>
                        <ul class="dropdown-menu" aria-labelledby="roleDropdown">
                            <li>@Html.ActionLink("View", "Index", "AssessmentMgnt", null, new { @class = "dropdown-item" })</li>
                            <li>@Html.ActionLink("Create", "Create", "AssessmentMgnt", null, new { @class = "dropdown-item" })</li>
                            <li>@Html.ActionLink("Edit", "Edit", "AssessmentMgnt", null, new { @class = "dropdown-item" })</li>
                            <li>@Html.ActionLink("Delete", "Delete", "AssessmentMgnt", null, new { @class = "dropdown-item" })</li>

                        </ul>
                    </li>

                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="roleDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            Competency Info
                        </a>
                        <ul class="dropdown-menu" aria-labelledby="roleDropdown">
                            <li>@Html.ActionLink("View", "Index", "CompetencyMgmt", null, new { @class = "dropdown-item" })</li>
                            <li>@Html.ActionLink("Create", "Create", "CompetencyMgmt", null, new { @class = "dropdown-item" })</li>
                            <li>@Html.ActionLink("Edit", "Edit", "CompetencyMgmt", null, new { @class = "dropdown-item" })</li>

                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="roleDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            CaseStudy Info
                        </a>
                        <ul class="dropdown-menu" aria-labelledby="roleDropdown">
                            <li>@Html.ActionLink("View", "Index", "CaseStudy", null, new { @class = "dropdown-item" })</li>
                            <li>@Html.ActionLink("Create", "Create", "CaseStudy", null, new { @class = "dropdown-item" })</li>
                            <li>@Html.ActionLink("Edit", "Edit", "CaseStudy", null, new { @class = "dropdown-item" })</li>

                        </ul>
                    </li>

                </ul>
            </div>
        </div>
    </nav>

    <!-- ✅ Main Content Area -->
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- ✅ Footer -->
    <footer class="text-center">
        <div class="container">
            <p class="mb-0">© 2025 TR Ltd. All rights reserved.</p>
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
