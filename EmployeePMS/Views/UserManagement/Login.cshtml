@model DL_CompetencyPMS.ViewModel.LoginViewModel

@{
    Layout = null;
    ViewBag.Title = "Login";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Login - Competency PMS</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            background: linear-gradient(to right, #d7e1ec, #f0f4f8);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-card {
            max-width: 420px;
            width: 100%;
            background-color: white;
            padding: 2rem;
            border-radius: 1rem;
            box-shadow: 0 0 30px rgba(0, 0, 0, 0.08);
        }

        .login-title {
            font-weight: 600;
            margin-bottom: 1.5rem;
            text-align: center;
            color: #2c3e50;
        }

        .btn-sky {
            background-color: lightskyblue;
            color: white;
        }

            .btn-sky:hover {
                background-color: deepskyblue;
            }
    </style>
</head>
<body>

    <div class="login-card">
        <h3 class="login-title">Competency PMS</h3>

        @using (Html.BeginForm("Login", "UserManagement", FormMethod.Post))
        {
            @Html.AntiForgeryToken()

            <div class="mb-3">
                @Html.LabelFor(m => m.UserID, new { @class = "form-label" })
                @Html.TextBoxFor(m => m.UserID, new { @class = "form-control", placeholder = "Enter your user ID" })
                @Html.ValidationMessageFor(m => m.UserID, "", new { @class = "text-danger" })
            </div>

            <div class="mb-3">
                @Html.LabelFor(m => m.Password, new { @class = "form-label" })
                @Html.PasswordFor(m => m.Password, new { @class = "form-control", placeholder = "Enter your password" })
                @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
            </div>

            <div class="d-grid">
                <button type="submit" class="btn btn-sky">Login</button>
            </div>
        }

        @if (ViewBag.ErrorMessage != null)
        {
            <div class="alert alert-danger mt-3 text-center">
                @ViewBag.ErrorMessage
            </div>
        }
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
