@model IEnumerable<DL_CompetencyPMS.Model.CaseStudySolutionInfo>
@{
    Layout = null;
    ViewBag.Title = "Create Casestudy";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Create CaseStudy - Competency PMS</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            background: linear-gradient(to right, #d7e1ec, #f0f4f8);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
        }

        .form-card {
            max-width: 600px;
            width: 100%;
            background-color: white;
            padding: 2rem;
            border-radius: 1rem;
            box-shadow: 0 0 30px rgba(0, 0, 0, 0.08);
            height: 90vh; /* Occupies 90% of the screen height */
            display: flex;
            flex-direction: column;
        }

        .form-content {
            overflow-y: auto;
            padding-right: 0.5rem; /* space for scrollbar */
            flex-grow: 1;
        }

        .form-title {
            font-weight: 600;
            margin-bottom: 1.5rem;
            text-align: center;
            color: #2c3e50;
        }

        .btn-sky {
            background-color: lightskyblue;
            color: white;
        }

            .btn-sky:hover {
                background-color: deepskyblue;
            }
    </style>

</head>
<body>

    <div class="form-card">
        <h3 class="form-title">CaseStudy Solution</h3>

        <div class="form-content">
            @using (Html.BeginForm("Create", "CaseStudy", FormMethod.Post))
            {
                @Html.AntiForgeryToken()

            

            <div class="mb-3">
                <label class="form-label">CaseStudy</label>
                <input name="CaseStudy" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">AssessmentID</label>
                <input name="AssessmentID" class="form-control"  />
            </div>

            <div class="mb-3">
                <label class="form-label">soln1</label>
                <input name="soln1" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Comp1</label>
                <input name="Comp1" class="form-control"  />
            </div>

            <div class="mb-3">
                <label class="form-label">soln2</label>
                <input name="soln2" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Comp2</label>
                <input name="Comp2" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">soln3</label>
                <input name="soln3" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Comp3</label>
                <input name="Comp3" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">soln4</label>
                <input name="soln4" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Comp4</label>
                <input name="Comp4" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Created By</label>
                <input type="date" name="CreatedBy" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
            </div>

            <div class="form-check mb-4">
                <input class="form-check-input" type="checkbox" name="IsReviewed" id="IsReviewed" />
                <label class="form-check-label" for="IsReviewed">IsReviewed</label>
            </div>

           

           

            <div class="d-grid">
                <button type="submit" class="btn btn-sky">Save</button>
            </div>
        }

            @if (ViewBag.ErrorMessage != null)
            {
                <div class="alert alert-danger mt-3 text-center">
                    @ViewBag.ErrorMessage
                </div>
            }
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
