@model IEnumerable<DL_CompetencyPMS.Model.AssessmentInfo>


@{
    Layout = "~/Views/Shared/_MyLayout.cshtml"; ;
    ViewBag.Title = "Assessments";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>@ViewBag.Title</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            background: linear-gradient(to right, #d7e1ec, #f0f4f8);
            padding: 40px;
        }

        .list-card {
            background-color: white;
            padding: 2rem;
            border-radius: 1rem;
            box-shadow: 0 0 30px rgba(0, 0, 0, 0.08);
        }

        .page-title {
            font-weight: 600;
            margin-bottom: 20px;
            color: #2c3e50;
            text-align: center;
        }

        .action-links a {
            margin-right: 8px;
        }
    </style>
</head>
<body>

    <div class="container">
        <div class="list-card">
            <h3 class="page-title">Roles</h3>



            <table class="table table-bordered table-striped table-hover">
                <thead class="table-light">
                    <tr>

                        <th>@Html.DisplayNameFor(model => model.First().AssessmentName)</th>
                       
                        <th>@Html.DisplayNameFor(model => model.First().AssmtDate)</th>
                        <th>@Html.DisplayNameFor(model => model.First().Description)</th>
                        <th>@Html.DisplayNameFor(model => model.First().IsActive)</th>

                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>

                                <td>@item.AssessmentName</td>
                                <td>@item.AssmtDate</td>
                                <td>@item.Description</td>
                                <td>
                                    <input type="checkbox" disabled @(item.IsActive ? "checked" : "") />
                                </td>
                                
                                <td class="text-center action-links">
                                    @Html.ActionLink("Edit", "Edit", new { id = item.AssessmentID }, new { @class = "btn btn-sm btn-info text-white" })
                                    @Html.ActionLink("Details", "Details", new { id = item.AssessmentID }, new { @class = "btn btn-sm btn-info text-white" })

                                </td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted">No roles found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</body>
</html>
