@using EBookSpace.Models.DTOs.UI
@model PaymentDTO
<div class="row">
    <div class ="col-md-4">
        <form asp-action="IntiateOrder">
            <div class="form-group">
            <label asp-for="Name" class="form-control">  </label>
            <input asp-for="Name" class="form-control"/>
            </div>
            <div class="form-group">
            <label asp-for="MobileNumber" class="form-control">  </label>
            <input asp-for="MobileNumber" class="form-control" />
            </div>
            <div class="form-group">
            <label asp-for="Email" class="form-control">  </label>
            <input asp-for="Email" class="form-control" />
            </div>
            <div class="form-group">
            <label asp-for="TotalPrice" class="form-control">  </label>
            <input asp-for="TotalPrice" class="form-control" />
            </div>
          
            <div class="form-group">
                <input type ="submit" value="Continue To Pay" class="btn btn-primary"/>
            </div>
        </form>
    </div>
</div>
